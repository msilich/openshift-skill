// Privileged profile. Do not start OpenCode with --auto and approve only "once".
// Configure a model in the normal OpenCode configuration, then set
// OPENSHIFT_MCP_BINARY, OPENSHIFT_MCP_DAY2_CONFIG, and
// OPENSHIFT_MCP_DAY2_KUBECONFIG. Keep this profile disabled when not in use.
// Source baseline: openshift/openshift-mcp-server@a0a1c370fcce18f76cecdbb2e07d8f4dbafe92dd
{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "share": "disabled",
  "mcp": {
    "ocp_day2": {
      "type": "local",
      "command": [
        "{env:OPENSHIFT_MCP_BINARY}",
        "--config",
        "{env:OPENSHIFT_MCP_DAY2_CONFIG}",
        "--kubeconfig",
        "{env:OPENSHIFT_MCP_DAY2_KUBECONFIG}",
        "--cluster-provider",
        "disabled"
      ],
      "enabled": true
    }
  },
  "permission": {
    "*": "deny",
    "skill": {
      "*": "deny",
      "openshift-api": "allow",
      "openshift-docs": "allow",
      "openshift-mcp": "allow"
    },
    "read": {
      "*": "deny",
      ".agents/skills/**": "allow"
    },
    "grep": "allow",
    "glob": "allow",
    "question": "allow",
    "ocp_day2_*": "ask",
    "bash": {
      "*": "deny",
      "bash *openshift-api/scripts/collect-discovery.sh *": "ask",
      "oc --kubeconfig {env:OPENSHIFT_MCP_DAY2_KUBECONFIG} *": "ask",
      "oc --kubeconfig {env:OPENSHIFT_MCP_DAY2_KUBECONFIG} config current-context": "allow",
      "oc --kubeconfig {env:OPENSHIFT_MCP_DAY2_KUBECONFIG} whoami": "allow",
      "oc --kubeconfig {env:OPENSHIFT_MCP_DAY2_KUBECONFIG} whoami --show-server": "allow",
      "oc --kubeconfig {env:OPENSHIFT_MCP_DAY2_KUBECONFIG} login *": "deny",
      "oc --kubeconfig {env:OPENSHIFT_MCP_DAY2_KUBECONFIG} logout *": "deny",
      "oc --kubeconfig {env:OPENSHIFT_MCP_DAY2_KUBECONFIG} config view *": "deny",
      "oc --kubeconfig {env:OPENSHIFT_MCP_DAY2_KUBECONFIG} config use-context *": "deny",
      "oc --kubeconfig {env:OPENSHIFT_MCP_DAY2_KUBECONFIG} config set-*": "deny",
      "oc --kubeconfig {env:OPENSHIFT_MCP_DAY2_KUBECONFIG} config unset *": "deny",
      "oc --kubeconfig {env:OPENSHIFT_MCP_DAY2_KUBECONFIG} config delete-*": "deny",
      "oc --kubeconfig {env:OPENSHIFT_MCP_DAY2_KUBECONFIG} whoami -t": "deny",
      "oc --kubeconfig {env:OPENSHIFT_MCP_DAY2_KUBECONFIG} whoami --show-token": "deny"
    },
    "doom_loop": "ask"
  }
}
